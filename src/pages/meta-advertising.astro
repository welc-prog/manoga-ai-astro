---
import BenefitsGrid from '../components/BenefitsGrid.astro';
import CtaSection from '../components/CtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconCode from '../components/icons/IconCode.astro';
import IconLayout from '../components/icons/IconLayout.astro';
import IconTag from '../components/icons/IconTag.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import { t } from '../i18n/index.ts';
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.metaAdsTitle', lang)} description={t('meta.metaAdsDescription', lang)} lang={lang}>
  <section class="page-header hero-meta-ads">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
        <h1>Meta <span class="text-gradient">{t('services.advertising', lang)}</span></h1>
        <p class="page-header-description">{t('marketing.metaAds', lang)}</p>
        <a href="/contact" class="btn btn-primary mt-1">Get a Free Meta Ads Strategy &rarr;</a>
        <div class="hero-proof-strip">
          <span class="hero-proof-item">4.2x avg. ROAS</span>
          <span class="hero-proof-divider">|</span>
          <span class="hero-proof-item">Meta Business Partner</span>
        </div>
        <a href="/portfolio" class="hero-secondary-cta">See Our Work &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconTag />
          </div>
          <h3 class="card-title">{t('pages.metaAds.facebookAds', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.facebookAdsDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.metaAds.instagramAds', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.instagramAdsDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.metaAds.advantagePlus', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.advantagePlusDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.metaAds.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.metaAds.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.metaAds.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.metaAds.whyTitle', lang)}
    description={t('pages.metaAds.whyDesc', lang)}
    items={[
      { icon: IconTarget, titleKey: 'pages.metaAds.benefit1', descKey: 'pages.metaAds.benefit1Desc' },
      { icon: IconBarChart, titleKey: 'pages.metaAds.benefit2', descKey: 'pages.metaAds.benefit2Desc' },
      { icon: IconLayout, titleKey: 'pages.metaAds.benefit3', descKey: 'pages.metaAds.benefit3Desc' },
      { icon: IconCode, titleKey: 'pages.metaAds.benefit4', descKey: 'pages.metaAds.benefit4Desc' },
    ]}
  />

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.metaAds.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.metaAds.service1', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.metaAds.service2', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.metaAds.service3', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.metaAds.service4', lang)}</h3>
          <p class="card-text">{t('pages.metaAds.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.metaAds.faq1', answerKey: 'pages.metaAds.faq1Answer' },
      { questionKey: 'pages.metaAds.faq2', answerKey: 'pages.metaAds.faq2Answer' },
      { questionKey: 'pages.metaAds.faq3', answerKey: 'pages.metaAds.faq3Answer' },
      { questionKey: 'pages.metaAds.faq4', answerKey: 'pages.metaAds.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      {
        '@type': 'Question',
        'name': 'How has iOS 14 affected Meta advertising?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Tracking has become more challenging, but effective strategies exist. I use server-side tracking, Conversions API, and platform features to maintain performance.',
        },
      },
      {
        '@type': 'Question',
        'name': 'What budget do I need for Meta ads?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I recommend at least 3,000-5,000 DKK monthly to test and optimize effectively. Smaller budgets can work for very focused local campaigns.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Do you create the ad creative?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I can provide creative direction and guidance, work with your existing assets, or recommend creative partners depending on your needs.',
        },
      },
      {
        '@type': 'Question',
        'name': 'How do you measure success?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'We define KPIs based on your goals – whether that\'s cost per lead, ROAS, brand lift, or other metrics that matter to your business.',
        },
      },
    ],
  })}
  />
</Layout>

<style>
.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
