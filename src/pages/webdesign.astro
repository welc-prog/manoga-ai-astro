---
import BenefitsGrid from '../components/BenefitsGrid.astro';
import CtaSection from '../components/CtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconCode from '../components/icons/IconCode.astro';
import IconExternal from '../components/icons/IconExternal.astro';
import IconLayout from '../components/icons/IconLayout.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import { t } from '../i18n/index.ts';
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.webdesignTitle', lang)} description={t('meta.webdesignDescription', lang)} lang={lang}>
  <section class="page-header hero-webdesign">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
        <h1>{t('nav.webdesign', lang)}</h1>
        <p class="page-header-description">{t('marketing.webDesign', lang)}</p>
        <a href="/contact" class="btn btn-primary mt-1">Start Your Web Project &rarr;</a>
        <div class="hero-proof-strip">
          <span class="hero-proof-item">100/100 PageSpeed</span>
          <span class="hero-proof-divider">|</span>
          <span class="hero-proof-item">Astro + Nuxt</span>
        </div>
        <a href="/portfolio" class="hero-secondary-cta">See Our Work &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.webdesign.modernDesign', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.modernDesignDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.webdesign.aiDevelopment', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.aiDevelopmentDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.webdesign.conversionOptimization', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.conversionOptimizationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Demos Showcase -->
  <section class="section demos-showcase-section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">See Our Work</span>
        <h2>Live Demos — <span class="text-gradient">Try Them Now</span></h2>
        <p style="max-width: 620px; margin: 0 auto;">Every demo below is a real, interactive website. Not a mockup, not a video — the real thing. Built with the same tech we use for client projects.</p>
      </div>

      <div class="demos-preview-grid reveal">
        <a href="/demos/webshop/" class="demos-preview-card">
          <div class="demos-preview-bar">
            <span class="demos-dot"></span><span class="demos-dot"></span><span class="demos-dot"></span>
            <span class="demos-preview-url">manoga.digital/demos/webshop</span>
          </div>
          <div class="demos-preview-screen">
            <img src="/images/demos/webshop-hero.webp" alt="E-commerce webshop demo" loading="lazy" />
            <div class="demos-preview-overlay">
              <span class="demos-live-dot"></span>
              <span>E-Commerce Demo</span>
            </div>
          </div>
          <div class="demos-preview-footer">
            <div>
              <strong>Webshop with Stripe</strong>
              <span>Nuxt 4 · Tailwind · Stripe Checkout</span>
            </div>
            <span class="demos-explore-arrow">&rarr;</span>
          </div>
        </a>

        <a href="/demos/electrician/" class="demos-preview-card">
          <div class="demos-preview-bar">
            <span class="demos-dot"></span><span class="demos-dot"></span><span class="demos-dot"></span>
            <span class="demos-preview-url">manoga.digital/demos/electrician</span>
          </div>
          <div class="demos-preview-screen">
            <img src="/images/demos/electrician-hero.webp" alt="Electrician service business demo" loading="lazy" />
            <div class="demos-preview-overlay">
              <span class="demos-live-dot"></span>
              <span>Service Business Demo</span>
            </div>
          </div>
          <div class="demos-preview-footer">
            <div>
              <strong>Electrician Website</strong>
              <span>Nuxt 4 · Lead Generation · Blog</span>
            </div>
            <span class="demos-explore-arrow">&rarr;</span>
          </div>
        </a>
      </div>

      <div class="text-center" style="margin-top: var(--space-xl);">
        <a href="/demos" class="btn btn-primary">
          View Full Demo Page
          <IconExternal />
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.webdesign.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.webdesign.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.webdesign.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.webdesign.whyTitle', lang)}
    description={t('pages.webdesign.whyDesc', lang)}
    items={[
      { icon: IconTarget, titleKey: 'pages.webdesign.benefit1', descKey: 'pages.webdesign.benefit1Desc' },
      { icon: IconBarChart, titleKey: 'pages.webdesign.benefit2', descKey: 'pages.webdesign.benefit2Desc' },
      { icon: IconLayout, titleKey: 'pages.webdesign.benefit3', descKey: 'pages.webdesign.benefit3Desc' },
      { icon: IconCode, titleKey: 'pages.webdesign.benefit4', descKey: 'pages.webdesign.benefit4Desc' },
    ]}
  />

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.webdesign.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service1', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service2', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service3', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service4', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.webdesign.faq1', answerKey: 'pages.webdesign.faq1Answer' },
      { questionKey: 'pages.webdesign.faq2', answerKey: 'pages.webdesign.faq2Answer' },
      { questionKey: 'pages.webdesign.faq3', answerKey: 'pages.webdesign.faq3Answer' },
      { questionKey: 'pages.webdesign.faq4', answerKey: 'pages.webdesign.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      {
        '@type': 'Question',
        'name': 'What platform do you build websites on?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I primarily use Nuxt 4 and Vue.js for custom sites, which delivers excellent performance and SEO. For simpler needs, I can work with WordPress or other platforms.',
        },
      },
      {
        '@type': 'Question',
        'name': 'How long does a website project take?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Simple landing pages can be completed in 1-2 weeks. Full custom websites typically take 4-8 weeks depending on complexity.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Do you provide hosting?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I can recommend and set up hosting, typically on Vercel or similar modern platforms that offer excellent performance and security.',
        },
      },
      {
        '@type': 'Question',
        'name': 'What about content and images?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I can work with your existing content, help with content strategy, or recommend copywriters. Stock images or custom photography can be incorporated.',
        },
      },
    ],
  })}
  />
</Layout>

<style>
.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.demos-showcase-section {
  border-top: 1px solid rgba(59, 130, 246, 0.15);
  border-bottom: 1px solid rgba(59, 130, 246, 0.15);
}

.demos-preview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-lg);
  max-width: 1100px;
  margin: 0 auto;
}

.demos-preview-card {
  display: block;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
  overflow: hidden;
  background: var(--bg-surface);
  transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  text-decoration: none;
  color: inherit;
}

.demos-preview-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 28px 64px rgba(59, 130, 246, 0.22);
  border-color: var(--border-accent);
}

.demos-preview-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 1px solid var(--border-subtle);
}

.demos-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.demos-dot:first-child { background: #ff5f56; }
.demos-dot:nth-child(2) { background: #ffbd2e; }
.demos-dot:nth-child(3) { background: #27c93f; }

.demos-preview-url {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-left: 8px;
  background: rgba(255, 255, 255, 0.05);
  padding: 3px 10px;
  border-radius: var(--radius-full);
}

.demos-preview-screen {
  position: relative;
  aspect-ratio: 16/10;
  overflow: hidden;
}

.demos-preview-screen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s var(--ease);
}

.demos-preview-card:hover .demos-preview-screen img {
  transform: scale(1.05);
}

.demos-preview-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 50%);
  display: flex;
  align-items: flex-end;
  gap: 8px;
  padding: 1.5rem;
  color: white;
  font-size: 0.9rem;
  font-weight: 600;
  opacity: 0;
  transition: opacity 0.3s var(--ease);
}

.demos-preview-card:hover .demos-preview-overlay {
  opacity: 1;
}

.demos-live-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #22c55e;
  flex-shrink: 0;
  animation: demos-pulse 2s ease-in-out infinite;
}

@keyframes demos-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
  50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
}

.demos-preview-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-top: 1px solid var(--border-subtle);
}

.demos-preview-footer strong {
  display: block;
  color: var(--text-primary);
  font-size: 0.95rem;
  margin-bottom: 2px;
}

.demos-preview-footer span {
  color: var(--text-muted);
  font-size: 0.8rem;
}

.demos-explore-arrow {
  font-size: 1.5rem;
  color: var(--accent);
  transition: transform 0.3s var(--ease);
}

.demos-preview-card:hover .demos-explore-arrow {
  transform: translateX(4px);
}

@media (max-width: 768px) {
  .demos-preview-grid {
    grid-template-columns: 1fr;
    max-width: 500px;
  }
}
</style>
