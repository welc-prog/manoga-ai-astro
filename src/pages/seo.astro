---
import BenefitsGrid from '../components/BenefitsGrid.astro';
import CtaSection from '../components/CtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconBrain from '../components/icons/IconBrain.astro';
import IconCode from '../components/icons/IconCode.astro';
import IconSearch from '../components/icons/IconSearch.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import MidCta from '../components/MidCta.astro';
import ProofStrip from '../components/ProofStrip.astro';
import { t } from '../i18n/index.ts';
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.seoTitle', lang)} description={t('meta.seoDescription', lang)} lang={lang}>
  <section class="page-header hero-seo">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
        <h1>SEO <span class="text-gradient">Services</span></h1>
        <p class="page-header-description">{t('marketing.seo', lang)}</p>
        <a href="/contact" class="btn btn-primary mt-1">Get a Free SEO Audit →</a>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <ProofStrip items={[
    { number: '3-6', label: 'Months to Page 1 Results' },
    { number: '15+', label: 'Years SEO Experience' },
    { number: 'ROI', label: 'Focused Strategy' },
  ]}
  />

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Recent Result</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">+340%</span>
            <span class="mini-result-desc">organic traffic growth</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">Page 1</span>
            <span class="mini-result-desc">for 12 target keywords</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">6 months</span>
            <span class="mini-result-desc">to achieve results</span>
          </div>
        </div>
        <p class="mini-result-context">Multilingual content platform — from launch to page 1 rankings</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconSearch />
          </div>
          <h3 class="card-title">{t('pages.seo.technicalSeo', lang)}</h3>
          <p class="card-text">{t('pages.seo.technicalSeoDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.seo.contentStrategy', lang)}</h3>
          <p class="card-text">{t('pages.seo.contentStrategyDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.seo.analyticsReporting', lang)}</h3>
          <p class="card-text">{t('pages.seo.analyticsReportingDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.seo.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.seo.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.seo.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- SEO Methodology -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">Our Approach</span>
        <h2>The SEO <span class="text-gradient">Methodology</span></h2>
      </div>
      <div class="methodology-grid reveal">
        <div class="methodology-step">
          <div class="methodology-number">01</div>
          <h3>Audit</h3>
          <p>Deep technical analysis of your site's SEO health, identifying issues and opportunities.</p>
          <span class="methodology-deliverable">Deliverable: 50+ point technical audit report</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">02</div>
          <h3>Strategy</h3>
          <p>Custom roadmap based on your competitive landscape and business objectives.</p>
          <span class="methodology-deliverable">Deliverable: 90-day keyword & content roadmap</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">03</div>
          <h3>Execute</h3>
          <p>Technical fixes, content creation, and link building — all data-driven.</p>
          <span class="methodology-deliverable">Deliverable: Monthly implementation sprints</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">04</div>
          <h3>Measure</h3>
          <p>Monthly reporting with clear KPIs. We adjust strategy based on real data.</p>
          <span class="methodology-deliverable">Deliverable: KPI dashboard with weekly updates</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.seo.whyTitle', lang)}
    description={t('pages.seo.whyDesc', lang)}
    items={[
      { icon: IconBarChart, titleKey: 'pages.seo.benefit1', descKey: 'pages.seo.benefit1Desc' },
      { icon: IconTarget, titleKey: 'pages.seo.benefit2', descKey: 'pages.seo.benefit2Desc' },
      { icon: IconBrain, titleKey: 'pages.seo.benefit3', descKey: 'pages.seo.benefit3Desc' },
      { icon: IconShield, titleKey: 'pages.seo.benefit4', descKey: 'pages.seo.benefit4Desc' },
    ]}
  />

  <!-- Mid-page CTA -->
  <MidCta href="/contact" text="Book Free Consultation →" />

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.seo.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.seo.service1', lang)}</h3>
          <p class="card-text">{t('pages.seo.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.seo.service2', lang)}</h3>
          <p class="card-text">{t('pages.seo.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.seo.service3', lang)}</h3>
          <p class="card-text">{t('pages.seo.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.seo.service4', lang)}</h3>
          <p class="card-text">{t('pages.seo.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.seo.faq1', answerKey: 'pages.seo.faq1Answer' },
      { questionKey: 'pages.seo.faq2', answerKey: 'pages.seo.faq2Answer' },
      { questionKey: 'pages.seo.faq3', answerKey: 'pages.seo.faq3Answer' },
      { questionKey: 'pages.seo.faq4', answerKey: 'pages.seo.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      {
        '@type': 'Question',
        'name': 'How long does SEO take to show results?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'SEO is a long-term investment. Most clients see initial improvements within 3-4 months, with significant results typically appearing after 6-12 months.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Can you guarantee #1 rankings?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'No legitimate SEO professional can guarantee specific rankings. I focus on sustainable growth and measurable improvements in traffic and conversions.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Do you build backlinks?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'I focus on earning links through quality content and outreach, not buying or manipulating links which can harm your site.',
        },
      },
      {
        '@type': 'Question',
        'name': 'How do you measure SEO success?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Beyond rankings, I track organic traffic, conversions from organic search, and overall visibility improvements. Real business metrics matter most.',
        },
      },
    ],
  })}
  />
</Layout>

<style>
.page-header .text-gradient { color: #7cb342; }
.page-header { position: relative; overflow: hidden; border-left: 4px solid #7cb342; }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(124, 179, 66, 0.03) 20px, rgba(124, 179, 66, 0.03) 21px);
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
