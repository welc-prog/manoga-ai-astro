---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/index.ts';
import IconBrain from '../components/icons/IconBrain.astro';
import IconSearch from '../components/icons/IconSearch.astro';
import IconCode from '../components/icons/IconCode.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconWorkshop from '../components/icons/IconWorkshop.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.aiConsultingTitle', lang)} description={t('meta.aiConsultingDescription', lang)} lang={lang}>
  <section class="page-header">
    <div class="container">
      <div class="page-header-with-image">
        <div class="page-header-content">
          <span class="page-subtitle">{t('services.whatWeDo', lang)}</span>
          <h1>{t('services.aiConsulting', lang)}</h1>
          <p class="page-header-description">{t('services.aiConsultingDesc', lang)}</p>
        </div>
        <div class="page-header-image">
          <img src="/images/ai-consulting.webp" alt={t('services.aiConsulting', lang)} loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">10x</span>
          <span class="proof-label">Development Speed</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">AI</span>
          <span class="proof-label">Strategy to Implementation</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">100%</span>
          <span class="proof-label">Hands-on Approach</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Client Outcome</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">60%</span>
            <span class="mini-result-desc">time saved on workflows</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">3 weeks</span>
            <span class="mini-result-desc">from audit to first AI tool</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">ROI</span>
            <span class="mini-result-desc">positive within 90 days</span>
          </div>
        </div>
        <p class="mini-result-context">Enterprise AI integration — marketing automation + content workflows</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconBrain />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.strategy', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.strategyDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconSearch />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.audit', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.auditDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.implementation', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.implementationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.aiConsulting.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.aiConsulting.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.aiConsulting.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.aiConsulting.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.aiConsulting.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h3>{t('pages.aiConsulting.benefit1', lang)}</h3>
          <p>{t('pages.aiConsulting.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h3>{t('pages.aiConsulting.benefit2', lang)}</h3>
          <p>{t('pages.aiConsulting.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconWorkshop />
          </div>
          <h3>{t('pages.aiConsulting.benefit3', lang)}</h3>
          <p>{t('pages.aiConsulting.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h3>{t('pages.aiConsulting.benefit4', lang)}</h3>
          <p>{t('pages.aiConsulting.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <a href="/contact" class="btn btn-primary btn-sm">Book Free Consultation &rarr;</a>
  </div>

  <!-- Process Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.ourApproach', lang)}</span>
        <h2>{t('pages.aiConsulting.processTitle', lang)}</h2>
      </div>

      <div class="process-grid reveal">
        <div class="process-step">
          <div class="process-number">1</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep1', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep1Desc', lang)}</p>
          <span class="process-deliverable">&rarr; AI Readiness Score + Opportunity Map</span>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep2', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep2Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Custom AI Strategy Document</span>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep3', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep3Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Working Prototypes + Team Training</span>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep4', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep4Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Monthly Performance Reports</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h3 class="faq-question">{t('pages.aiConsulting.faq1', lang)}</h3>
          <p class="faq-answer">{t('pages.aiConsulting.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.aiConsulting.faq2', lang)}</h3>
          <p class="faq-answer">{t('pages.aiConsulting.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.aiConsulting.faq3', lang)}</h3>
          <p class="faq-answer">{t('pages.aiConsulting.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.aiConsulting.faq4', lang)}</h3>
          <p class="faq-answer">{t('pages.aiConsulting.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does an AI consulting engagement typically last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Initial assessments usually take 2-4 weeks. Full strategic engagements can range from 1-3 months depending on scope. Implementation support is ongoing as needed."
        }
      },
      {
        "@type": "Question",
        "name": "Do we need technical staff to benefit from AI consulting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Part of my job is translating technical AI concepts into business terms. I work with executive teams, marketing departments, operations – anyone who can benefit from AI."
        }
      },
      {
        "@type": "Question",
        "name": "What industries do you have experience with?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "My background spans e-commerce, SaaS, professional services, and more. AI principles apply across industries, though specific applications vary."
        }
      },
      {
        "@type": "Question",
        "name": "How do you stay current with AI developments?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "I'm actively building AI-powered applications and constantly experimenting with new tools and techniques. This hands-on experience means I can separate hype from reality."
        }
      }
    ]
  })} />
</Layout>

<style>
.page-header .text-gradient { color: #a78bfa; }
.page-header { position: relative; overflow: hidden; border-bottom: 2px solid rgba(167, 139, 250, 0.4); }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(-45deg, transparent, transparent 30px, rgba(167, 139, 250, 0.03) 30px, rgba(167, 139, 250, 0.03) 31px);
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h3 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
