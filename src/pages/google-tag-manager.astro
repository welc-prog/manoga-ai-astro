---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/index.ts';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import IconCode from '../components/icons/IconCode.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.gtmTitle', lang)} description={t('meta.gtmDescription', lang)} lang={lang}>
  <section class="page-header">
    <div class="container">
      <div class="page-header-with-image">
        <div class="page-header-content">
          <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
          <h1>Google Tag <span class="text-gradient">Manager</span></h1>
          <p class="page-header-description">{t('marketing.gtm', lang)}</p>
        </div>
        <div class="page-header-image">
          <img src="/images/gtm.webp" alt="Google Tag Manager" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.gtm.gtmSetup', lang)}</h3>
          <p class="card-text">{t('pages.gtm.gtmSetupDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconTarget />
          </div>
          <h3 class="card-title">{t('pages.gtm.conversionTracking', lang)}</h3>
          <p class="card-text">{t('pages.gtm.conversionTrackingDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.gtm.ga4Integration', lang)}</h3>
          <p class="card-text">{t('pages.gtm.ga4IntegrationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.gtm.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.gtm.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.gtm.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.gtm.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.gtm.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h3>{t('pages.gtm.benefit1', lang)}</h3>
          <p>{t('pages.gtm.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconCode />
          </div>
          <h3>{t('pages.gtm.benefit2', lang)}</h3>
          <p>{t('pages.gtm.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h3>{t('pages.gtm.benefit3', lang)}</h3>
          <p>{t('pages.gtm.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h3>{t('pages.gtm.benefit4', lang)}</h3>
          <p>{t('pages.gtm.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.gtm.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.gtm.service1', lang)}</h3>
          <p class="card-text">{t('pages.gtm.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.gtm.service2', lang)}</h3>
          <p class="card-text">{t('pages.gtm.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.gtm.service3', lang)}</h3>
          <p class="card-text">{t('pages.gtm.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.gtm.service4', lang)}</h3>
          <p class="card-text">{t('pages.gtm.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h3 class="faq-question">{t('pages.gtm.faq1', lang)}</h3>
          <p class="faq-answer">{t('pages.gtm.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.gtm.faq2', lang)}</h3>
          <p class="faq-answer">{t('pages.gtm.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.gtm.faq3', lang)}</h3>
          <p class="faq-answer">{t('pages.gtm.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.gtm.faq4', lang)}</h3>
          <p class="faq-answer">{t('pages.gtm.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do I need a developer to implement GTM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basic implementations can be done without developer help. Complex setups may need minimal developer involvement for data layer implementation."
        }
      },
      {
        "@type": "Question",
        "name": "How do I know if my current tracking is wrong?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common signs include mismatched numbers between platforms, missing conversions, duplicate events, or difficulty answering basic questions about user behavior."
        }
      },
      {
        "@type": "Question",
        "name": "What about privacy regulations like GDPR?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "I set up tracking with consent mode and cookie banners to ensure compliance with privacy regulations."
        }
      },
      {
        "@type": "Question",
        "name": "Do you provide documentation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Every implementation comes with documentation explaining what's tracking, how it works, and how to make common changes."
        }
      }
    ]
  })} />
</Layout>

<style>
.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h3 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
