---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/index.ts';
import IconSearch from '../../components/icons/IconSearch.astro';
import IconCode from '../../components/icons/IconCode.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import IconBrain from '../../components/icons/IconBrain.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconArrowRight from '../../components/icons/IconArrowRight.astro';

const lang = 'da';  // Hardcode for Danish pages
const prefix = '/da';  // Hardcode for Danish pages
---

<Layout title={t('meta.seoTitle', lang)} description={t('meta.seoDescription', lang)} lang={lang}>
  <section class="page-header">
    <div class="container">
      <div class="page-header-with-image">
        <div class="page-header-content">
          <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
          <h1>SEO <span class="text-gradient">ydelser</span></h1>
          <p class="page-header-description">{t('marketing.seo', lang)}</p>
          <a href="/da/contact" class="btn btn-primary mt-1">Få en Gratis SEO Audit →</a>
        </div>
        <div class="page-header-image">
          <img src="/images/seo-analytics.webp" alt="SEO-analyse" />
        </div>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">3-6</span>
          <span class="proof-label">Måneder til side 1-resultater</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">15+</span>
          <span class="proof-label">Års SEO-erfaring</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">ROI</span>
          <span class="proof-label">Fokuseret strategi</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Seneste resultat</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">+340%</span>
            <span class="mini-result-desc">vækst i organisk trafik</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">Side 1</span>
            <span class="mini-result-desc">for 12 mål-keywords</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">6 måneder</span>
            <span class="mini-result-desc">til at opnå resultater</span>
          </div>
        </div>
        <p class="mini-result-context">Flersproget indholdsplatform — fra launch til side 1 placeringer</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconSearch />
          </div>
          <h3 class="card-title">{t('pages.seo.technicalSeo', lang)}</h3>
          <p class="card-text">{t('pages.seo.technicalSeoDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.seo.contentStrategy', lang)}</h3>
          <p class="card-text">{t('pages.seo.contentStrategyDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.seo.analyticsReporting', lang)}</h3>
          <p class="card-text">{t('pages.seo.analyticsReportingDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.seo.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.seo.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.seo.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- SEO Metodikken -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">Vores tilgang</span>
        <h2>SEO <span class="text-gradient">Metodikken</span></h2>
      </div>
      <div class="methodology-grid reveal">
        <div class="methodology-step">
          <div class="methodology-number">01</div>
          <h3>Revision</h3>
          <p>Dybdegående teknisk analyse af dit sites SEO-sundhed, der identificerer problemer og muligheder.</p>
          <span class="methodology-deliverable">Leverance: 50+ punkts teknisk audit-rapport</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">02</div>
          <h3>Strategi</h3>
          <p>Skræddersyet plan baseret på jeres konkurrencesituation og forretningsmål.</p>
          <span class="methodology-deliverable">Leverance: 90-dages keyword & indholdsplan</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">03</div>
          <h3>Eksekvering</h3>
          <p>Tekniske rettelser, indholdsproduktion og linkbuilding — alt datadrevet.</p>
          <span class="methodology-deliverable">Leverance: Månedlige implementerings-sprints</span>
        </div>
        <div class="methodology-step">
          <div class="methodology-number">04</div>
          <h3>Måling</h3>
          <p>Månedlig rapportering med klare KPI'er. Vi justerer strategien ud fra data.</p>
          <span class="methodology-deliverable">Leverance: KPI-dashboard med ugentlige opdateringer</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.seo.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.seo.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h4>{t('pages.seo.benefit1', lang)}</h4>
          <p>{t('pages.seo.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h4>{t('pages.seo.benefit2', lang)}</h4>
          <p>{t('pages.seo.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBrain />
          </div>
          <h4>{t('pages.seo.benefit3', lang)}</h4>
          <p>{t('pages.seo.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h4>{t('pages.seo.benefit4', lang)}</h4>
          <p>{t('pages.seo.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <a href="/da/contact" class="btn btn-primary btn-sm">Book Gratis Konsultation &rarr;</a>
  </div>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.seo.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h4 class="card-title">{t('pages.seo.service1', lang)}</h4>
          <p class="card-text">{t('pages.seo.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.seo.service2', lang)}</h4>
          <p class="card-text">{t('pages.seo.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.seo.service3', lang)}</h4>
          <p class="card-text">{t('pages.seo.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.seo.service4', lang)}</h4>
          <p class="card-text">{t('pages.seo.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h4 class="faq-question">{t('pages.seo.faq1', lang)}</h4>
          <p class="faq-answer">{t('pages.seo.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.seo.faq2', lang)}</h4>
          <p class="faq-answer">{t('pages.seo.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.seo.faq3', lang)}</h4>
          <p class="faq-answer">{t('pages.seo.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.seo.faq4', lang)}</h4>
          <p class="faq-answer">{t('pages.seo.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header .text-gradient { color: #7cb342; }
.page-header { position: relative; overflow: hidden; border-left: 4px solid #7cb342; }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(124, 179, 66, 0.03) 20px, rgba(124, 179, 66, 0.03) 21px);
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h4 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
