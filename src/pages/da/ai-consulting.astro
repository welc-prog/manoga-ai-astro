---
import BenefitsGrid from '../../components/BenefitsGrid.astro';
import CtaSection from '../../components/CtaSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconBrain from '../../components/icons/IconBrain.astro';
import IconCode from '../../components/icons/IconCode.astro';
import IconSearch from '../../components/icons/IconSearch.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import IconWorkshop from '../../components/icons/IconWorkshop.astro';
import MidCta from '../../components/MidCta.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da'; // Hardcode for Danish pages
const prefix = '/da'; // Hardcode for Danish pages
---

<Layout title={t('meta.aiConsultingTitle', lang)} description={t('meta.aiConsultingDescription', lang)} lang={lang}>
  <section class="page-header hero-ai-consulting">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('services.whatWeDo', lang)}</span>
        <h1>{t('services.aiConsulting', lang)}</h1>
        <p class="page-header-description">{t('services.aiConsultingDesc', lang)}</p>
        <a href="/da/contact" class="btn btn-primary mt-1">Book en Gratis AI-konsultation →</a>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <ProofStrip items={[
    { number: '10x', label: 'Udviklingshastighed' },
    { number: 'AI', label: 'Strategi til implementering' },
    { number: '100%', label: 'Praktisk tilgang' },
  ]}
  />

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Kundeudbytte</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">60%</span>
            <span class="mini-result-desc">tidsbesparelse på workflows</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">3 uger</span>
            <span class="mini-result-desc">fra audit til første AI-værktøj</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">ROI</span>
            <span class="mini-result-desc">positiv inden for 90 dage</span>
          </div>
        </div>
        <p class="mini-result-context">Enterprise AI-integration — marketing automation + indholdsworkflows</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconBrain />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.strategy', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.strategyDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconSearch />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.audit', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.auditDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.aiConsulting.implementation', lang)}</h3>
          <p class="card-text">{t('pages.aiConsulting.implementationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.aiConsulting.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.aiConsulting.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.aiConsulting.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.aiConsulting.whyTitle', lang)}
    description={t('pages.aiConsulting.whyDesc', lang)}
    items={[
      { icon: IconTarget, titleKey: 'pages.aiConsulting.benefit1', descKey: 'pages.aiConsulting.benefit1Desc' },
      { icon: IconShield, titleKey: 'pages.aiConsulting.benefit2', descKey: 'pages.aiConsulting.benefit2Desc' },
      { icon: IconWorkshop, titleKey: 'pages.aiConsulting.benefit3', descKey: 'pages.aiConsulting.benefit3Desc' },
      { icon: IconBarChart, titleKey: 'pages.aiConsulting.benefit4', descKey: 'pages.aiConsulting.benefit4Desc' },
    ]}
  />

  <!-- Mid-page CTA -->
  <MidCta href="/da/contact" text="Book gratis samtale →" />

  <!-- Process Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.ourApproach', lang)}</span>
        <h2>{t('pages.aiConsulting.processTitle', lang)}</h2>
      </div>

      <div class="process-grid reveal">
        <div class="process-step">
          <div class="process-number">1</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep1', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep1Desc', lang)}</p>
          <span class="process-deliverable">&rarr; AI-parathedsscore + Mulighedskort</span>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep2', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep2Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Skræddersyet AI-strategidokument</span>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep3', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep3Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Fungerende prototyper + Teamtræning</span>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h3 class="process-title">{t('pages.aiConsulting.processStep4', lang)}</h3>
          <p class="process-text">{t('pages.aiConsulting.processStep4Desc', lang)}</p>
          <span class="process-deliverable">&rarr; Månedlige performancerapporter</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.aiConsulting.faq1', answerKey: 'pages.aiConsulting.faq1Answer' },
      { questionKey: 'pages.aiConsulting.faq2', answerKey: 'pages.aiConsulting.faq2Answer' },
      { questionKey: 'pages.aiConsulting.faq3', answerKey: 'pages.aiConsulting.faq3Answer' },
      { questionKey: 'pages.aiConsulting.faq4', answerKey: 'pages.aiConsulting.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />
</Layout>

<style>
.page-header .text-gradient { color: #a78bfa; }
.page-header { position: relative; overflow: hidden; border-bottom: 2px solid rgba(167, 139, 250, 0.4); }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(-45deg, transparent, transparent 30px, rgba(167, 139, 250, 0.03) 30px, rgba(167, 139, 250, 0.03) 31px);
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
