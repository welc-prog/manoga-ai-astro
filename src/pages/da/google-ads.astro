---
import BenefitsGrid from '../../components/BenefitsGrid.astro';
import CtaSection from '../../components/CtaSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconLayout from '../../components/icons/IconLayout.astro';
import IconSearch from '../../components/icons/IconSearch.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import MidCta from '../../components/MidCta.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da'; // Hardcode for Danish pages
const prefix = '/da'; // Hardcode for Danish pages
---

<Layout title={t('meta.googleAdsTitle', lang)} description={t('meta.googleAdsDescription', lang)} lang={lang}>
  <section class="page-header hero-google-ads">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
        <h1>Google <span class="text-gradient">Ads</span></h1>
        <p class="page-header-description">{t('marketing.googleAds', lang)}</p>
        <a href="/da/contact" class="btn btn-primary mt-1">Få en Gratis Kontogennemgang →</a>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <ProofStrip items={[
    { number: 'ROAS', label: 'Optimerede kampagner' },
    { number: '0', label: 'Langvarige kontrakter' },
    { number: '24h', label: 'Svartid' },
  ]}
  />

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Kampagne-snapshot</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">4.2x</span>
            <span class="mini-result-desc">gennemsnitlig ROAS</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">-38%</span>
            <span class="mini-result-desc">pris pr. lead</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">2 uger</span>
            <span class="mini-result-desc">til første konverteringer</span>
          </div>
        </div>
        <p class="mini-result-context">Performance Max kampagne — B2B servicevirksomhed</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconTarget />
          </div>
          <h3 class="card-title">{t('pages.googleAds.searchCampaigns', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.searchCampaignsDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.googleAds.displayRemarketing', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.displayRemarketingDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.googleAds.performanceMax', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.performanceMaxDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.googleAds.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.googleAds.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.googleAds.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Kampagnetyper -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">Kampagnetyper</span>
        <h2>Vælg din <span class="text-gradient">Vækstvej</span></h2>
      </div>
      <div class="campaign-grid reveal">
        <div class="campaign-type">
          <div class="campaign-badge">Search</div>
          <p>Fang brugere med høj købsintention, der aktivt søger efter dine ydelser. Bedst til leadgenerering og direkte respons.</p>
        </div>
        <div class="campaign-type featured">
          <div class="campaign-badge">Performance Max</div>
          <p>AI-drevne kampagner på tværs af alle Google-kanaler. Maksimal rækkevidde med intelligent budgetallokering.</p>
        </div>
        <div class="campaign-type">
          <div class="campaign-badge">Display & Remarketing</div>
          <p>Bliv top-of-mind med visuelle annoncer på tværs af Google Display Netværket. Perfekt til brandbevidsthed og retargeting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hvad du kan forvente -->
  <section class="section section-sm">
    <div class="container">
      <div class="expectation-strip">
        <div class="expectation-item">
          <span class="expectation-label">Typisk opsætning</span>
          <span class="expectation-value">3-5 hverdage</span>
        </div>
        <div class="expectation-item">
          <span class="expectation-label">Første resultater</span>
          <span class="expectation-value">Inden for 7 dage</span>
        </div>
        <div class="expectation-item">
          <span class="expectation-label">Optimerings-cyklus</span>
          <span class="expectation-value">Ugentlige gennemgange</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.googleAds.whyTitle', lang)}
    description={t('pages.googleAds.whyDesc', lang)}
    items={[
      { icon: IconShield, titleKey: 'pages.googleAds.benefit1', descKey: 'pages.googleAds.benefit1Desc' },
      { icon: IconTarget, titleKey: 'pages.googleAds.benefit2', descKey: 'pages.googleAds.benefit2Desc' },
      { icon: IconBarChart, titleKey: 'pages.googleAds.benefit3', descKey: 'pages.googleAds.benefit3Desc' },
      { icon: IconSearch, titleKey: 'pages.googleAds.benefit4', descKey: 'pages.googleAds.benefit4Desc' },
    ]}
  />

  <!-- Mid-page CTA -->
  <MidCta href="/da/contact" text="Book gratis samtale →" />

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.googleAds.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.googleAds.service1', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.googleAds.service2', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.googleAds.service3', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.googleAds.service4', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.googleAds.faq1', answerKey: 'pages.googleAds.faq1Answer' },
      { questionKey: 'pages.googleAds.faq2', answerKey: 'pages.googleAds.faq2Answer' },
      { questionKey: 'pages.googleAds.faq3', answerKey: 'pages.googleAds.faq3Answer' },
      { questionKey: 'pages.googleAds.faq4', answerKey: 'pages.googleAds.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />
</Layout>

<style>
.page-header .text-gradient { color: #4285f4; }
.page-header { position: relative; overflow: hidden; border-top: 3px solid #4285f4; }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(66, 133, 244, 0.04) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
