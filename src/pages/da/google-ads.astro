---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/index.ts';
import IconTarget from '../../components/icons/IconTarget.astro';
import IconLayout from '../../components/icons/IconLayout.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconSearch from '../../components/icons/IconSearch.astro';
import IconArrowRight from '../../components/icons/IconArrowRight.astro';

const lang = 'da';  // Hardcode for Danish pages
const prefix = '/da';  // Hardcode for Danish pages
---

<Layout title={t('meta.googleAdsTitle', lang)} description={t('meta.googleAdsDescription', lang)} lang={lang}>
  <section class="page-header">
    <div class="container">
      <div class="page-header-with-image">
        <div class="page-header-content">
          <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
          <h1>Google <span class="text-gradient">Ads</span></h1>
          <p class="page-header-description">{t('marketing.googleAds', lang)}</p>
        </div>
        <div class="page-header-image">
          <img src="/images/google-ads.webp" alt="Google Ads" />
        </div>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">ROAS</span>
          <span class="proof-label">Optimerede kampagner</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">0</span>
          <span class="proof-label">Langvarige kontrakter</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">24h</span>
          <span class="proof-label">Svartid</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Kampagne-snapshot</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">4.2x</span>
            <span class="mini-result-desc">gennemsnitlig ROAS</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">-38%</span>
            <span class="mini-result-desc">pris pr. lead</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">2 uger</span>
            <span class="mini-result-desc">til første konverteringer</span>
          </div>
        </div>
        <p class="mini-result-context">Performance Max kampagne — B2B servicevirksomhed</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconTarget />
          </div>
          <h3 class="card-title">{t('pages.googleAds.searchCampaigns', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.searchCampaignsDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.googleAds.displayRemarketing', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.displayRemarketingDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.googleAds.performanceMax', lang)}</h3>
          <p class="card-text">{t('pages.googleAds.performanceMaxDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.googleAds.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.googleAds.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.googleAds.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Kampagnetyper -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">Kampagnetyper</span>
        <h2>Vælg din <span class="text-gradient">Vækstvej</span></h2>
      </div>
      <div class="campaign-grid reveal">
        <div class="campaign-type">
          <div class="campaign-badge">Search</div>
          <p>Fang brugere med høj købsintention, der aktivt søger efter dine ydelser. Bedst til leadgenerering og direkte respons.</p>
        </div>
        <div class="campaign-type featured">
          <div class="campaign-badge">Performance Max</div>
          <p>AI-drevne kampagner på tværs af alle Google-kanaler. Maksimal rækkevidde med intelligent budgetallokering.</p>
        </div>
        <div class="campaign-type">
          <div class="campaign-badge">Display & Remarketing</div>
          <p>Bliv top-of-mind med visuelle annoncer på tværs af Google Display Netværket. Perfekt til brandbevidsthed og retargeting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hvad du kan forvente -->
  <section class="section section-sm">
    <div class="container">
      <div class="expectation-strip">
        <div class="expectation-item">
          <span class="expectation-label">Typisk opsætning</span>
          <span class="expectation-value">3-5 hverdage</span>
        </div>
        <div class="expectation-item">
          <span class="expectation-label">Første resultater</span>
          <span class="expectation-value">Inden for 7 dage</span>
        </div>
        <div class="expectation-item">
          <span class="expectation-label">Optimerings-cyklus</span>
          <span class="expectation-value">Ugentlige gennemgange</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.googleAds.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.googleAds.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h4>{t('pages.googleAds.benefit1', lang)}</h4>
          <p>{t('pages.googleAds.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h4>{t('pages.googleAds.benefit2', lang)}</h4>
          <p>{t('pages.googleAds.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h4>{t('pages.googleAds.benefit3', lang)}</h4>
          <p>{t('pages.googleAds.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconSearch />
          </div>
          <h4>{t('pages.googleAds.benefit4', lang)}</h4>
          <p>{t('pages.googleAds.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <a href="/da/contact" class="btn btn-primary btn-sm">Book Gratis Konsultation &rarr;</a>
  </div>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.googleAds.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h4 class="card-title">{t('pages.googleAds.service1', lang)}</h4>
          <p class="card-text">{t('pages.googleAds.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.googleAds.service2', lang)}</h4>
          <p class="card-text">{t('pages.googleAds.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.googleAds.service3', lang)}</h4>
          <p class="card-text">{t('pages.googleAds.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.googleAds.service4', lang)}</h4>
          <p class="card-text">{t('pages.googleAds.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h4 class="faq-question">{t('pages.googleAds.faq1', lang)}</h4>
          <p class="faq-answer">{t('pages.googleAds.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.googleAds.faq2', lang)}</h4>
          <p class="faq-answer">{t('pages.googleAds.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.googleAds.faq3', lang)}</h4>
          <p class="faq-answer">{t('pages.googleAds.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.googleAds.faq4', lang)}</h4>
          <p class="faq-answer">{t('pages.googleAds.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header .text-gradient { color: #4285f4; }
.page-header { position: relative; overflow: hidden; border-top: 3px solid #4285f4; }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(66, 133, 244, 0.04) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h4 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
