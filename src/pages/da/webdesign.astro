---
import BenefitsGrid from '../../components/BenefitsGrid.astro';
import CtaSection from '../../components/CtaSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconCode from '../../components/icons/IconCode.astro';
import IconLayout from '../../components/icons/IconLayout.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da'; // Hardcode for Danish pages
const prefix = '/da'; // Hardcode for Danish pages
---

<Layout title={t('meta.webdesignTitle', lang)} description={t('meta.webdesignDescription', lang)} lang={lang}>
  <section class="page-header hero-webdesign">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('marketing.tagline', lang)}</span>
        <h1>{t('nav.webdesign', lang)}</h1>
        <p class="page-header-description">{t('marketing.webDesign', lang)}</p>
        <a href="/da/contact" class="btn btn-primary mt-1">Start dit webprojekt &rarr;</a>
        <div class="hero-proof-strip">
          <span class="hero-proof-item">100/100 PageSpeed</span>
          <span class="hero-proof-divider">|</span>
          <span class="hero-proof-item">Astro + Nuxt</span>
        </div>
        <a href="/da/portfolio" class="hero-secondary-cta">Se vores arbejde &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.webdesign.modernDesign', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.modernDesignDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.webdesign.aiDevelopment', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.aiDevelopmentDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBarChart />
          </div>
          <h3 class="card-title">{t('pages.webdesign.conversionOptimization', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.conversionOptimizationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.webdesign.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.webdesign.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.webdesign.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.webdesign.whyTitle', lang)}
    description={t('pages.webdesign.whyDesc', lang)}
    items={[
      { icon: IconTarget, titleKey: 'pages.webdesign.benefit1', descKey: 'pages.webdesign.benefit1Desc' },
      { icon: IconBarChart, titleKey: 'pages.webdesign.benefit2', descKey: 'pages.webdesign.benefit2Desc' },
      { icon: IconLayout, titleKey: 'pages.webdesign.benefit3', descKey: 'pages.webdesign.benefit3Desc' },
      { icon: IconCode, titleKey: 'pages.webdesign.benefit4', descKey: 'pages.webdesign.benefit4Desc' },
    ]}
  />

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.webdesign.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service1', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service2', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service3', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.webdesign.service4', lang)}</h3>
          <p class="card-text">{t('pages.webdesign.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.webdesign.faq1', answerKey: 'pages.webdesign.faq1Answer' },
      { questionKey: 'pages.webdesign.faq2', answerKey: 'pages.webdesign.faq2Answer' },
      { questionKey: 'pages.webdesign.faq3', answerKey: 'pages.webdesign.faq3Answer' },
      { questionKey: 'pages.webdesign.faq4', answerKey: 'pages.webdesign.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />
</Layout>

<style>
.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
