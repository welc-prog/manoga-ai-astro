---
import IconArrowRight from '../../components/icons/IconArrowRight.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconBrain from '../../components/icons/IconBrain.astro';
import IconCode from '../../components/icons/IconCode.astro';
import IconLayout from '../../components/icons/IconLayout.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da'; // Hardcode for Danish pages
const prefix = '/da'; // Hardcode for Danish pages
---

<Layout title={t('meta.vibecodingTitle', lang)} description={t('meta.vibecodingDescription', lang)} lang={lang}>
  <section class="page-header hero-vibecoding">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('services.whatWeDo', lang)}</span>
        <h1><span class="text-gradient">Vibecoding</span></h1>
        <p class="page-header-description">{t('services.vibecoding', lang)}</p>
        <a href="/da/contact" class="btn btn-primary mt-1">Start Dit Projekt →</a>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">10x</span>
          <span class="proof-label">Hurtigere end traditionel udvikling</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">MVP</span>
          <span class="proof-label">På dage, ikke måneder</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">QA</span>
          <span class="proof-label">Produktionsklar kode</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Seneste build</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">4 uger</span>
            <span class="mini-result-desc">fra nul til produktion</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">100</span>
            <span class="mini-result-desc">Lighthouse score</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">5 sprog</span>
            <span class="mini-result-desc">flersproget support</span>
          </div>
        </div>
        <p class="mini-result-context">WeLoveEverythingCrypto — komplet platform bygget med vibecoding</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.rapidPrototyping', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.rapidPrototypingDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.fullStack', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.fullStackDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBrain />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.aiIntegration', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.aiIntegrationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.vibecoding.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.vibecoding.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.vibecoding.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Hvad der bliver leveret -->
  <section class="section section-sm">
    <div class="container">
      <div class="text-center mb-3">
        <h2>Hvad der bliver <span class="text-gradient">leveret</span></h2>
      </div>
      <div class="shipping-examples">
        <div class="shipping-example">
          <span class="shipping-timeline">Uge 1-2</span>
          <h4>MVP Launch</h4>
          <p>Kernefunktioner, autentificering, responsivt design, deployet til produktion</p>
        </div>
        <div class="shipping-example">
          <span class="shipping-timeline">Uge 3-4</span>
          <h4>Fuldt Produkt</h4>
          <p>Avancerede funktioner, integrationer, analyse, SEO-optimering, performance-tuning</p>
        </div>
        <div class="shipping-example">
          <span class="shipping-timeline">Løbende</span>
          <h4>Vækst & Support</h4>
          <p>Feature-iterationer, overvågning, fejlrettelser, skalering af infrastruktur</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.vibecoding.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.vibecoding.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconCode />
          </div>
          <h4>{t('pages.vibecoding.benefit1', lang)}</h4>
          <p>{t('pages.vibecoding.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h4>{t('pages.vibecoding.benefit2', lang)}</h4>
          <p>{t('pages.vibecoding.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h4>{t('pages.vibecoding.benefit3', lang)}</h4>
          <p>{t('pages.vibecoding.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h4>{t('pages.vibecoding.benefit4', lang)}</h4>
          <p>{t('pages.vibecoding.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <a href="/da/contact" class="btn btn-primary btn-sm">Book Gratis Konsultation &rarr;</a>
  </div>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.vibecoding.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h4 class="card-title">{t('pages.vibecoding.service1', lang)}</h4>
          <p class="card-text">{t('pages.vibecoding.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.vibecoding.service2', lang)}</h4>
          <p class="card-text">{t('pages.vibecoding.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.vibecoding.service3', lang)}</h4>
          <p class="card-text">{t('pages.vibecoding.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h4 class="card-title">{t('pages.vibecoding.service4', lang)}</h4>
          <p class="card-text">{t('pages.vibecoding.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('process.tagline', lang)}</span>
        <h2>{t('process.the', lang)}<span class="text-gradient">Vibecoding</span>{t('process.process', lang)}</h2>
      </div>

      <div class="process-grid reveal">
        <div class="process-step">
          <div class="process-number">1</div>
          <h4 class="process-title">{t('process.discovery', lang)}</h4>
          <p class="process-text">{t('process.discoveryDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h4 class="process-title">{t('process.design', lang)}</h4>
          <p class="process-text">{t('process.designDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h4 class="process-title">{t('process.develop', lang)}</h4>
          <p class="process-text">{t('process.developDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h4 class="process-title">{t('process.deploy', lang)}</h4>
          <p class="process-text">{t('process.deployDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h4 class="faq-question">{t('pages.vibecoding.faq1', lang)}</h4>
          <p class="faq-answer">{t('pages.vibecoding.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.vibecoding.faq2', lang)}</h4>
          <p class="faq-answer">{t('pages.vibecoding.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.vibecoding.faq3', lang)}</h4>
          <p class="faq-answer">{t('pages.vibecoding.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h4 class="faq-question">{t('pages.vibecoding.faq4', lang)}</h4>
          <p class="faq-answer">{t('pages.vibecoding.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header { position: relative; overflow: hidden; border-right: 4px solid var(--accent); }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(0deg, transparent 24px, rgba(201, 165, 92, 0.02) 24px, rgba(201, 165, 92, 0.02) 25px, transparent 25px),
    linear-gradient(90deg, transparent 24px, rgba(201, 165, 92, 0.02) 24px, rgba(201, 165, 92, 0.02) 25px, transparent 25px);
  background-size: 25px 25px;
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h4 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
