---
import IconArrowRight from '../../components/icons/IconArrowRight.astro';
import IconExternal from '../../components/icons/IconExternal.astro';
import IconPhone from '../../components/icons/IconPhone.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da';
const prefix = '/da';

const offer1Bullets = [
  'Google Ads — Search, Performance Max, Shopping, Demand Gen, YouTube',
  'Meta — Advantage+, retargeting, kreative test-frameworks',
  'Apple Search Ads, Microsoft Advertising, LinkedIn Ads',
  'Teknisk SEO, indholdsstruktur, on-page og intern linking',
  'GTM, GA4, server-side tracking, Conversions API, consent mode v2',
];
const offer2Bullets = [
  'Vibecoding — produktionsapps i Astro, Nuxt eller Next',
  'AI-rådgivning — hvor AI giver mening, hvor ikke, hvad det reelt koster',
  'Workshops — halv- eller heldag for små teams, hands-on',
  'Interne værktøjer — dashboards, datapipelines, automatisering',
  'Full-stack: frontend, backend, deployment, monitoring',
];

const channels = [
  { name: 'Google Ads', since: '2010' },
  { name: 'Meta', since: '2012' },
  { name: 'YouTube Ads', since: '2013' },
  { name: 'Apple Search Ads', since: '2018' },
  { name: 'Microsoft Ads', since: '2014' },
  { name: 'LinkedIn Ads', since: '2015' },
  { name: 'Google Tag Manager', since: '2013' },
  { name: 'GA4 · server-side', since: 'aktuelt' },
  { name: 'Teknisk SEO', since: '2010' },
  { name: 'Astro · Nuxt · Next', since: 'aktuelt' },
];
---

<Layout title={t('meta.homeTitle', lang)} description={t('meta.homeDescription', lang)} lang={lang}>
  <!-- ============ HERO ============ -->
  <section class="mh-hero">
    <div class="mh-hero-glow" aria-hidden="true"></div>
    <div class="container mh-hero-inner">
      <div class="mh-hero-col-main">
        <span class="mh-kicker">
          <span class="mh-kicker-dot" aria-hidden="true"></span>
          {t('hero.tagline', lang)}
        </span>

        <h1 class="mh-hero-h1">
          {t('hero.title', lang)}
          <br />
          <span class="mh-hero-h1-accent">{t('hero.titleAccent', lang)}</span>
        </h1>

        <p class="mh-hero-lede">{t('hero.description', lang)}</p>

        <div class="mh-hero-actions">
          <a href={`${prefix}/contact`} class="mh-btn mh-btn--primary">
            {t('hero.cta', lang)}
            <IconArrowRight />
          </a>
          <a href={`${prefix}/portfolio`} class="mh-btn mh-btn--ghost">
            {t('hero.secondary', lang)}
          </a>
        </div>
      </div>

      <aside class="mh-hero-col-side" aria-label="At a glance">
        <div class="mh-card mh-id-card">
          <div class="mh-id-head">
            <span class="mh-id-avatar" aria-hidden="true">K</span>
            <div>
              <p class="mh-id-name">Kenneth Abueg</p>
              <p class="mh-id-role">Senior paid-media-operatør · AI-native builder</p>
            </div>
          </div>

          <dl class="mh-id-facts">
            <div>
              <dt>Baseret i</dt>
              <dd>Nibe, Danmark</dd>
            </div>
            <div>
              <dt>Har lavet dette siden</dt>
              <dd>2010 · 15 år</dd>
            </div>
            <div>
              <dt>Opsætning</dt>
              <dd>Solo-operatør — ikke et bureau</dd>
            </div>
            <div>
              <dt>Arbejder med</dt>
              <dd>Founders, in-house marketing-ansvarlige, CMOs</dd>
            </div>
            <div>
              <dt>Svartid</dt>
              <dd>Inden for én arbejdsdag</dd>
            </div>
          </dl>

          <div class="mh-id-status">
            <span class="mh-status-dot" aria-hidden="true"></span>
            Ledig til nye projekter i Q2 2026
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ============ TRUST STRIP ============ -->
  <section class="mh-trust">
    <div class="container">
      <span class="mh-eyebrow">{t('home.trustEyebrow', lang)}</span>
      <ul class="mh-trust-grid">
        {channels.map(c => (
          <li class="mh-trust-item">
            <span class="mh-trust-name">{c.name}</span>
            <span class="mh-trust-since">siden {c.since}</span>
          </li>
        ))}
      </ul>
      <p class="mh-trust-note">{t('home.trustNote', lang)}</p>
    </div>
  </section>

  <!-- ============ WHY ME ============ -->
  <section class="mh-why">
    <div class="container">
      <header class="mh-section-head">
        <span class="mh-eyebrow">{t('home.whyEyebrow', lang)}</span>
        <h2 class="mh-h2">{t('home.whyTitle', lang)}</h2>
      </header>

      <div class="mh-why-grid">
        <article class="mh-why-card">
          <span class="mh-why-num">01</span>
          <h3 class="mh-card-title">{t('home.why1Title', lang)}</h3>
          <p class="mh-card-body">{t('home.why1Desc', lang)}</p>
        </article>
        <article class="mh-why-card">
          <span class="mh-why-num">02</span>
          <h3 class="mh-card-title">{t('home.why2Title', lang)}</h3>
          <p class="mh-card-body">{t('home.why2Desc', lang)}</p>
        </article>
        <article class="mh-why-card">
          <span class="mh-why-num">03</span>
          <h3 class="mh-card-title">{t('home.why3Title', lang)}</h3>
          <p class="mh-card-body">{t('home.why3Desc', lang)}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ OFFERINGS ============ -->
  <section class="mh-offer">
    <div class="container">
      <header class="mh-section-head mh-section-head--center">
        <span class="mh-eyebrow">{t('home.offerEyebrow', lang)}</span>
        <h2 class="mh-h2">{t('home.offerTitle', lang)}</h2>
        <p class="mh-section-sub">{t('home.offerSubtitle', lang)}</p>
      </header>

      <div class="mh-offer-grid">
        <article class="mh-offer-card">
          <div class="mh-offer-visual">
            <img src="/images/icon-google-ads.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-meta-ads.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-seo.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-gtm.webp" alt="" loading="lazy" width="60" height="60" />
          </div>
          <span class="mh-offer-kicker">{t('home.offer1Kicker', lang)}</span>
          <h3 class="mh-offer-title">{t('home.offer1Title', lang)}</h3>
          <p class="mh-offer-lede">{t('home.offer1Lede', lang)}</p>
          <ul class="mh-offer-bullets">
            {offer1Bullets.map(b => <li>{b}</li>)}
          </ul>
          <a href={`${prefix}/seo`} class="mh-offer-link">
            {t('home.offer1Cta', lang)} <IconArrowRight />
          </a>
        </article>

        <article class="mh-offer-card mh-offer-card--alt">
          <div class="mh-offer-visual">
            <img src="/images/icon-vibecoding.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-ai-consulting.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-workshops.webp" alt="" loading="lazy" width="60" height="60" />
            <img src="/images/icon-webdesign.webp" alt="" loading="lazy" width="60" height="60" />
          </div>
          <span class="mh-offer-kicker">{t('home.offer2Kicker', lang)}</span>
          <h3 class="mh-offer-title">{t('home.offer2Title', lang)}</h3>
          <p class="mh-offer-lede">{t('home.offer2Lede', lang)}</p>
          <ul class="mh-offer-bullets">
            {offer2Bullets.map(b => <li>{b}</li>)}
          </ul>
          <a href={`${prefix}/ai-consulting`} class="mh-offer-link">
            {t('home.offer2Cta', lang)} <IconArrowRight />
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ PORTFOLIO ============ -->
  <section class="mh-work">
    <div class="container">
      <header class="mh-section-head">
        <span class="mh-eyebrow">{t('home.portfolioEyebrow', lang)}</span>
        <h2 class="mh-h2">{t('home.portfolioTitle', lang)}</h2>
        <p class="mh-section-sub">{t('home.portfolioSubtitle', lang)}</p>
      </header>

      <article class="mh-featured">
        <a href="https://weloveeverythingcrypto.com" target="_blank" rel="noopener" class="mh-featured-media">
          <img src="/images/portfolio-crypto.webp" alt="WeLoveEverythingCrypto" loading="lazy" />
          <span class="mh-featured-visit">
            Besøg live <IconExternal />
          </span>
        </a>
        <div class="mh-featured-body">
          <span class="mh-chip">{t('home.welcTag', lang)}</span>
          <h3 class="mh-featured-title">WeLoveEverythingCrypto</h3>
          <p class="mh-featured-role">{t('home.welcRole', lang)}</p>
          <p class="mh-featured-story">{t('home.welcStory', lang)}</p>
          <dl class="mh-featured-facts">
            <div><dt>Stack</dt><dd>Nuxt 4 · TypeScript · Vercel</dd></div>
            <div><dt>Sprog</dt><dd>5</dd></div>
            <div><dt>Artikler</dt><dd>1.000+</dd></div>
            <div><dt>Bygget af</dt><dd>Kenneth, solo</dd></div>
          </dl>
        </div>
      </article>

      <div class="mh-work-grid">
        <article class="mh-case">
          <a href="https://handballtracker.com" target="_blank" rel="noopener" class="mh-case-media">
            <img src="/images/portfolio-handball.webp" alt="Handball Tracker" loading="lazy" />
          </a>
          <div class="mh-case-body">
            <h3 class="mh-case-title">Handball Tracker</h3>
            <p class="mh-case-role">{t('home.handballRole', lang)}</p>
            <p class="mh-case-story">{t('home.handballStory', lang)}</p>
            <a href="https://handballtracker.com" target="_blank" rel="noopener" class="mh-case-link">
              handballtracker.com <IconExternal />
            </a>
          </div>
        </article>

        <article class="mh-case">
          <a href="https://simpleclaude.news" target="_blank" rel="noopener" class="mh-case-media">
            <img src="/images/portfolio-claude-daily.svg" alt="Claude Daily" loading="lazy" />
          </a>
          <div class="mh-case-body">
            <h3 class="mh-case-title">Claude Daily</h3>
            <p class="mh-case-role">{t('home.claudeDailyRole', lang)}</p>
            <p class="mh-case-story">{t('home.claudeDailyStory', lang)}</p>
            <a href="https://simpleclaude.news" target="_blank" rel="noopener" class="mh-case-link">
              simpleclaude.news <IconExternal />
            </a>
          </div>
        </article>

        <article class="mh-case">
          <a href="https://letmeclaudethatforyou.live" target="_blank" rel="noopener" class="mh-case-media">
            <img src="/images/portfolio-lmctfy.svg" alt="Let Me Claude That For You" loading="lazy" />
          </a>
          <div class="mh-case-body">
            <h3 class="mh-case-title">Let Me Claude That For You</h3>
            <p class="mh-case-role">{t('home.lmctfyRole', lang)}</p>
            <p class="mh-case-story">{t('home.lmctfyStory', lang)}</p>
            <a href="https://letmeclaudethatforyou.live" target="_blank" rel="noopener" class="mh-case-link">
              letmeclaudethatforyou.live <IconExternal />
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="mh-about">
    <div class="container">
      <div class="mh-about-inner">
        <header class="mh-about-head">
          <span class="mh-eyebrow">{t('home.aboutEyebrow', lang)}</span>
          <h2 class="mh-h2">{t('home.aboutTitle', lang)}</h2>
        </header>
        <div class="mh-about-body">
          <p>{t('home.aboutBody1', lang)}</p>
          <p>{t('home.aboutBody2', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ENGAGEMENTS ============ -->
  <section class="mh-engage">
    <div class="container">
      <header class="mh-section-head">
        <span class="mh-eyebrow">{t('home.engagementEyebrow', lang)}</span>
        <h2 class="mh-h2">{t('home.engagementTitle', lang)}</h2>
        <p class="mh-section-sub">{t('home.engagementSubtitle', lang)}</p>
      </header>

      <div class="mh-engage-grid">
        <article class="mh-engage-card">
          <h3 class="mh-card-title">{t('home.engage1Title', lang)}</h3>
          <p class="mh-engage-price">{t('home.engage1Price', lang)}</p>
          <p class="mh-card-body">{t('home.engage1Desc', lang)}</p>
        </article>
        <article class="mh-engage-card mh-engage-card--feature">
          <h3 class="mh-card-title">{t('home.engage2Title', lang)}</h3>
          <p class="mh-engage-price">{t('home.engage2Price', lang)}</p>
          <p class="mh-card-body">{t('home.engage2Desc', lang)}</p>
        </article>
        <article class="mh-engage-card">
          <h3 class="mh-card-title">{t('home.engage3Title', lang)}</h3>
          <p class="mh-engage-price">{t('home.engage3Price', lang)}</p>
          <p class="mh-card-body">{t('home.engage3Desc', lang)}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="mh-cta">
    <div class="container">
      <div class="mh-cta-card">
        <div class="mh-cta-glow" aria-hidden="true"></div>
        <div class="mh-cta-body">
          <h2 class="mh-cta-title">{t('cta.title', lang)}</h2>
          <p class="mh-cta-sub">{t('cta.subtitle', lang)}</p>
        </div>
        <div class="mh-cta-actions">
          <a href={`${prefix}/contact`} class="mh-btn mh-btn--primary">
            {t('cta.button', lang)}
            <IconArrowRight />
          </a>
          <a href="tel:+4550587900" class="mh-cta-phone">
            <IconPhone />
            +45 50 58 79 00
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     MANOGA HOMEPAGE V3 — CONFIDENT SOLO STUDIO
     Rich, warm, premium. No italic flips, no monospace everywhere.
     ============================================================ */

  :root {
    --mh-bg: #0a0a0c;
    --mh-bg-raised: #121217;
    --mh-bg-card: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.012));
    --mh-bg-card-alt: linear-gradient(180deg, rgba(201,165,92,0.05), rgba(201,165,92,0.01));
    --mh-border: rgba(255,255,255,0.08);
    --mh-border-bright: rgba(255,255,255,0.14);
    --mh-border-gold: rgba(201,165,92,0.32);
    --mh-text: #f5f5f7;
    --mh-text-muted: rgba(245,245,247,0.72);
    --mh-text-dim: rgba(245,245,247,0.55);
    --mh-gold: #d4b46a;
    --mh-gold-soft: #c9a55c;
    --mh-gold-deep: #a78b4a;
  }

  /* Normalise against the legacy global cascade */
  :global(main) :where(.mh-hero, .mh-trust, .mh-why, .mh-offer, .mh-work, .mh-about, .mh-engage, .mh-cta) {
    border-top: none !important;
  }

  .mh-hero,
  .mh-trust,
  .mh-why,
  .mh-offer,
  .mh-work,
  .mh-about,
  .mh-engage,
  .mh-cta {
    position: relative;
    padding: clamp(4.5rem, 8vw, 7.5rem) 0;
  }
  .mh-hero { padding-top: clamp(7rem, 11vw, 10rem); padding-bottom: clamp(3.5rem, 6vw, 5rem); }

  /* ============ SHARED ATOMS ============ */
  .mh-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mh-gold);
    font-weight: 600;
  }

  .mh-h2 {
    font-family: var(--font-heading), 'Inter', sans-serif;
    font-size: clamp(2rem, 4.4vw, 3.125rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--mh-text);
    margin: 0 !important;
    max-width: 22ch;
  }

  .mh-section-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    max-width: 46rem;
  }
  .mh-section-head--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    align-items: center;
  }
  .mh-section-head--center .mh-h2 { max-width: 24ch; }

  .mh-section-sub {
    color: var(--mh-text-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }
  .mh-section-head--center .mh-section-sub { margin: 0 auto; }

  .mh-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--mh-text);
    margin: 0 !important;
  }

  .mh-card-body {
    color: var(--mh-text-muted);
    line-height: 1.65;
    font-size: 0.975rem;
    margin: 0;
  }

  /* ============ BUTTONS ============ */
  .mh-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.95rem 1.6rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border: 1px solid transparent;
    transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
    white-space: nowrap;
  }

  .mh-btn--primary {
    background: linear-gradient(180deg, var(--mh-gold), var(--mh-gold-deep));
    color: #1a1206;
    box-shadow: 0 1px 0 rgba(255,255,255,0.15) inset, 0 8px 24px -10px rgba(201,165,92,0.55);
  }
  .mh-btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.2) inset, 0 12px 28px -10px rgba(201,165,92,0.7);
  }
  .mh-btn--primary :global(svg) { width: 14px; height: 14px; }

  .mh-btn--ghost {
    background: rgba(255,255,255,0.03);
    color: var(--mh-text);
    border-color: var(--mh-border-bright);
  }
  .mh-btn--ghost:hover {
    background: rgba(255,255,255,0.06);
    border-color: var(--mh-border-gold);
  }

  /* ============ HERO ============ */
  .mh-hero {
    overflow: hidden;
  }

  .mh-hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 55% 45% at 75% 20%, rgba(201,165,92,0.18), transparent 60%),
      radial-gradient(ellipse 45% 60% at 10% 80%, rgba(101,130,200,0.07), transparent 60%);
    pointer-events: none;
  }

  .mh-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.25fr 0.9fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .mh-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mh-gold);
    font-weight: 600;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--mh-border-gold);
    border-radius: 999px;
    background: rgba(201,165,92,0.06);
    align-self: flex-start;
  }

  .mh-kicker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--mh-gold);
    box-shadow: 0 0 12px rgba(201,165,92,0.8);
    animation: mh-pulse 2.2s ease-out infinite;
  }
  @keyframes mh-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .mh-hero-col-main {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .mh-hero-h1 {
    font-family: var(--font-heading), 'Inter', sans-serif;
    font-size: clamp(2.75rem, 6.2vw, 4.5rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--mh-text);
    margin: 0 !important;
  }

  .mh-hero-h1-accent {
    background: linear-gradient(120deg, #f5e8c8 0%, var(--mh-gold) 55%, var(--mh-gold-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .mh-hero-lede {
    color: var(--mh-text-muted);
    font-size: clamp(1.0625rem, 1.3vw, 1.2rem);
    line-height: 1.65;
    max-width: 40em;
    margin: 0;
  }

  .mh-hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  /* Hero side card */
  .mh-hero-col-side {
    display: flex;
    align-items: stretch;
  }

  .mh-card {
    background: var(--mh-bg-card);
    border: 1px solid var(--mh-border);
    border-radius: 20px;
    padding: 1.75rem;
    position: relative;
    backdrop-filter: blur(8px);
  }

  .mh-id-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mh-id-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--mh-border);
  }

  .mh-id-avatar {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--mh-gold), var(--mh-gold-deep));
    color: #1a1206;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.3rem;
    flex-shrink: 0;
    box-shadow: 0 4px 14px -4px rgba(201,165,92,0.5);
  }

  .mh-id-name {
    margin: 0;
    color: var(--mh-text);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

