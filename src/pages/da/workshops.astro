---
import BenefitsGrid from '../../components/BenefitsGrid.astro';
import CtaSection from '../../components/CtaSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import IconBarChart from '../../components/icons/IconBarChart.astro';
import IconBrain from '../../components/icons/IconBrain.astro';
import IconCode from '../../components/icons/IconCode.astro';
import IconShield from '../../components/icons/IconShield.astro';
import IconTarget from '../../components/icons/IconTarget.astro';
import IconWorkshop from '../../components/icons/IconWorkshop.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'da'; // Hardcode for Danish pages
const prefix = '/da'; // Hardcode for Danish pages
---

<Layout title={t('meta.workshopsTitle', lang)} description={t('meta.workshopsDescription', lang)} lang={lang}>
  <section class="page-header hero-workshops">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('services.whatWeDo', lang)}</span>
        <h1>{t('services.workshops', lang)}</h1>
        <p class="page-header-description">{t('services.workshopsDesc', lang)}</p>
        <a href="/da/contact" class="btn btn-primary mt-1">Book en workshop &rarr;</a>
        <div class="hero-proof-strip">
          <span class="hero-proof-item">Praktisk Undervisning</span>
          <span class="hero-proof-divider">|</span>
          <span class="hero-proof-item">Hold p&aring; 5-20</span>
        </div>
        <a href="/da/portfolio" class="hero-secondary-cta">Se vores arbejde &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconWorkshop />
          </div>
          <h3 class="card-title">{t('pages.workshops.promptEngineering', lang)}</h3>
          <p class="card-text">{t('pages.workshops.promptEngineeringDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.workshops.vibecodingBootcamp', lang)}</h3>
          <p class="card-text">{t('pages.workshops.vibecodingBootcampDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBrain />
          </div>
          <h3 class="card-title">{t('pages.workshops.aiForBusiness', lang)}</h3>
          <p class="card-text">{t('pages.workshops.aiForBusinessDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.workshops.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.workshops.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.workshops.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <BenefitsGrid
    lang={lang}
    title={t('pages.workshops.whyTitle', lang)}
    description={t('pages.workshops.whyDesc', lang)}
    items={[
      { icon: IconBarChart, titleKey: 'pages.workshops.benefit1', descKey: 'pages.workshops.benefit1Desc' },
      { icon: IconWorkshop, titleKey: 'pages.workshops.benefit2', descKey: 'pages.workshops.benefit2Desc' },
      { icon: IconShield, titleKey: 'pages.workshops.benefit3', descKey: 'pages.workshops.benefit3Desc' },
      { icon: IconTarget, titleKey: 'pages.workshops.benefit4', descKey: 'pages.workshops.benefit4Desc' },
    ]}
  />

  <!-- Workshop Formats Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.howItWorks', lang)}</span>
        <h2>{t('pages.workshops.workshopsTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.workshops.workshop1', lang)}</h3>
          <p class="card-text">{t('pages.workshops.workshop1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.workshops.workshop2', lang)}</h3>
          <p class="card-text">{t('pages.workshops.workshop2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.workshops.workshop3', lang)}</h3>
          <p class="card-text">{t('pages.workshops.workshop3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.workshops.workshop4', lang)}</h3>
          <p class="card-text">{t('pages.workshops.workshop4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FaqSection
    lang={lang}
    items={[
      { questionKey: 'pages.workshops.faq1', answerKey: 'pages.workshops.faq1Answer' },
      { questionKey: 'pages.workshops.faq2', answerKey: 'pages.workshops.faq2Answer' },
      { questionKey: 'pages.workshops.faq3', answerKey: 'pages.workshops.faq3Answer' },
      { questionKey: 'pages.workshops.faq4', answerKey: 'pages.workshops.faq4Answer' },
    ]}
  />

  <!-- CTA -->
  <CtaSection lang={lang} prefix={prefix} />
</Layout>

<style>
.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}
</style>
