---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/index.ts';
import IconCode from '../components/icons/IconCode.astro';
import IconLayout from '../components/icons/IconLayout.astro';
import IconBrain from '../components/icons/IconBrain.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.vibecodingTitle', lang)} description={t('meta.vibecodingDescription', lang)} lang={lang}>
  <section class="page-header hero-vibecoding">
    <div class="container">
      <div class="page-header-content">
        <span class="page-subtitle">{t('services.whatWeDo', lang)}</span>
        <h1><span class="text-gradient">Vibecoding</span></h1>
        <p class="page-header-description">{t('services.vibecoding', lang)}</p>
        <a href="/contact" class="btn btn-primary mt-1">Start Your Project →</a>
      </div>
    </div>
  </section>

  <!-- Results Approach -->
  <section class="proof-strip">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <span class="proof-number">10x</span>
          <span class="proof-label">Faster Than Traditional Dev</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">MVP</span>
          <span class="proof-label">In Days, Not Months</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-item">
          <span class="proof-number">QA</span>
          <span class="proof-label">Production-Grade Code</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Result -->
  <section class="section section-sm">
    <div class="container">
      <div class="mini-result">
        <div class="mini-result-label">Latest Build</div>
        <div class="mini-result-content">
          <div class="mini-result-stat">
            <span class="mini-result-number">4 weeks</span>
            <span class="mini-result-desc">from zero to production</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">100</span>
            <span class="mini-result-desc">Lighthouse score</span>
          </div>
          <div class="mini-result-divider"></div>
          <div class="mini-result-stat">
            <span class="mini-result-number">5 langs</span>
            <span class="mini-result-desc">multilingual support</span>
          </div>
        </div>
        <p class="mini-result-context">WeLoveEverythingCrypto — full platform built with vibecoding</p>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="section">
    <div class="container">
      <div class="services-grid reveal">
        <div class="card">
          <div class="card-icon">
            <IconCode />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.rapidPrototyping', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.rapidPrototypingDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconLayout />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.fullStack', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.fullStackDesc', lang)}</p>
        </div>

        <div class="card">
          <div class="card-icon">
            <IconBrain />
          </div>
          <h3 class="card-title">{t('pages.vibecoding.aiIntegration', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.aiIntegrationDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('pages.vibecoding.aboutTitle', lang)}</h2>
        <p class="section-text">{t('pages.vibecoding.aboutDesc', lang)}</p>
        <p class="section-text">{t('pages.vibecoding.aboutDesc2', lang)}</p>
      </div>
    </div>
  </section>

  <!-- What Gets Shipped -->
  <section class="section section-sm">
    <div class="container">
      <div class="text-center mb-3">
        <h2>What Gets <span class="text-gradient">Shipped</span></h2>
      </div>
      <div class="shipping-examples">
        <div class="shipping-example">
          <span class="shipping-timeline">Week 1-2</span>
          <h4>MVP Launch</h4>
          <p>Core features, authentication, responsive design, deployed to production</p>
        </div>
        <div class="shipping-example">
          <span class="shipping-timeline">Week 3-4</span>
          <h4>Full Product</h4>
          <p>Advanced features, integrations, analytics, SEO optimization, performance tuning</p>
        </div>
        <div class="shipping-example">
          <span class="shipping-timeline">Ongoing</span>
          <h4>Growth & Support</h4>
          <p>Feature iterations, monitoring, bug fixes, scaling infrastructure</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.benefits', lang)}</span>
        <h2>{t('pages.vibecoding.whyTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('pages.vibecoding.whyDesc', lang)}</p>
      </div>

      <div class="benefits-grid reveal">
        <div class="benefit-item">
          <div class="benefit-icon">
            <IconCode />
          </div>
          <h3>{t('pages.vibecoding.benefit1', lang)}</h3>
          <p>{t('pages.vibecoding.benefit1Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconTarget />
          </div>
          <h3>{t('pages.vibecoding.benefit2', lang)}</h3>
          <p>{t('pages.vibecoding.benefit2Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconBarChart />
          </div>
          <h3>{t('pages.vibecoding.benefit3', lang)}</h3>
          <p>{t('pages.vibecoding.benefit3Desc', lang)}</p>
        </div>

        <div class="benefit-item">
          <div class="benefit-icon">
            <IconShield />
          </div>
          <h3>{t('pages.vibecoding.benefit4', lang)}</h3>
          <p>{t('pages.vibecoding.benefit4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <a href="/contact" class="btn btn-primary btn-sm">Book Free Consultation &rarr;</a>
  </div>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('services.whatWeDo', lang)}</span>
        <h2>{t('pages.vibecoding.servicesTitle', lang)}</h2>
      </div>

      <div class="services-grid reveal">
        <div class="card">
          <h3 class="card-title">{t('pages.vibecoding.service1', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.service1Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.vibecoding.service2', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.service2Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.vibecoding.service3', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.service3Desc', lang)}</p>
        </div>
        <div class="card">
          <h3 class="card-title">{t('pages.vibecoding.service4', lang)}</h3>
          <p class="card-text">{t('pages.vibecoding.service4Desc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('process.tagline', lang)}</span>
        <h2>{t('process.the', lang)}<span class="text-gradient">Vibecoding</span>{t('process.process', lang)}</h2>
      </div>

      <div class="process-grid reveal">
        <div class="process-step">
          <div class="process-number">1</div>
          <h3 class="process-title">{t('process.discovery', lang)}</h3>
          <p class="process-text">{t('process.discoveryDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h3 class="process-title">{t('process.design', lang)}</h3>
          <p class="process-text">{t('process.designDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h3 class="process-title">{t('process.develop', lang)}</h3>
          <p class="process-text">{t('process.developDesc', lang)}</p>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h3 class="process-title">{t('process.deploy', lang)}</h3>
          <p class="process-text">{t('process.deployDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.gotQuestions', lang)}</span>
        <h2>{t('common.faq', lang)}</h2>
      </div>

      <div class="faq-grid reveal">
        <div class="faq-item">
          <h3 class="faq-question">{t('pages.vibecoding.faq1', lang)}</h3>
          <p class="faq-answer">{t('pages.vibecoding.faq1Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.vibecoding.faq2', lang)}</h3>
          <p class="faq-answer">{t('pages.vibecoding.faq2Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.vibecoding.faq3', lang)}</h3>
          <p class="faq-answer">{t('pages.vibecoding.faq3Answer', lang)}</p>
        </div>

        <div class="faq-item">
          <h3 class="faq-question">{t('pages.vibecoding.faq4', lang)}</h3>
          <p class="faq-answer">{t('pages.vibecoding.faq4Answer', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is vibecoding just using ChatGPT to write code?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It's much more than that. Vibecoding requires understanding architecture, code quality, security, and user experience. AI is a powerful tool, but expertise is still essential."
        }
      },
      {
        "@type": "Question",
        "name": "What kinds of applications can you build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Web applications, internal tools, content platforms, dashboards, automation systems, and more. If it runs in a browser or on a server, I can likely build it."
        }
      },
      {
        "@type": "Question",
        "name": "Do you support the applications after launch?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. I offer ongoing support and maintenance packages to keep your application running smoothly and evolving with your needs."
        }
      },
      {
        "@type": "Question",
        "name": "What technologies do you use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Primarily Vue.js, Nuxt 3, Python, and modern cloud platforms. I choose the right tools for each project rather than forcing everything into one stack."
        }
      }
    ]
  })} />
</Layout>

<style>
.page-header { position: relative; overflow: hidden; border-right: 4px solid var(--accent); }
.page-header::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(0deg, transparent 24px, rgba(201, 165, 92, 0.02) 24px, rgba(201, 165, 92, 0.02) 25px, transparent 25px),
    linear-gradient(90deg, transparent 24px, rgba(201, 165, 92, 0.02) 24px, rgba(201, 165, 92, 0.02) 25px, transparent 25px);
  background-size: 25px 25px;
  pointer-events: none;
}

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.benefit-item {
  text-align: center;
  padding: var(--space-lg);
}

.benefit-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto var(--space-md);
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-icon :global(svg) {
  width: 28px;
  height: 28px;
  color: white;
}

.benefit-item h3 {
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.benefit-item p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.faq-item {
  background: transparent;
  padding: var(--space-lg) 0;
  border-radius: 0;
  border: none;
  border-bottom: 1px solid var(--border);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-size: 1.1rem;
}

.faq-answer {
  color: var(--text-secondary);
  line-height: 1.6;
}
</style>
