---
import IconArrowRight from '../../components/icons/IconArrowRight.astro';
import { t } from '../../i18n/index.ts';
import Layout from '../../layouts/Layout.astro';

const lang = 'en';
---

<Layout title={t('meta.testgenSubmitTitle', lang)} description={t('meta.testgenSubmitDescription', lang)} lang={lang} noindex={true}>
  <section class="page-header">
    <div class="container">
      <span class="page-subtitle">{t('pages.testgen.heroTagline', lang)}</span>
      <h1>{t('pages.testgen.submitTitle', lang)}</h1>
      <p class="page-header-description">{t('pages.testgen.submitDescription', lang)}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="submit-form-wrapper">
        <form
          class="contact-form"
          id="testgen-form"
          data-sending={t('pages.testgen.submitting', lang)}
          data-success-title={t('pages.testgen.submitSuccess', lang)}
          data-success-msg={t('pages.testgen.submitSuccessMsg', lang)}
          data-error-title={t('pages.testgen.submitError', lang)}
          data-error-msg={t('pages.testgen.submitErrorMsg', lang)}
        >
          <div class="form-group">
            <label class="form-label" for="repo-url">{t('pages.testgen.repoUrl', lang)} *</label>
            <input
              type="url"
              id="repo-url"
              name="repoUrl"
              class="form-input"
              required
              placeholder={t('pages.testgen.repoUrlPlaceholder', lang)}
              pattern="https://github\.com/.+"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="framework">{t('pages.testgen.framework', lang)}</label>
            <input
              type="text"
              id="framework"
              name="framework"
              class="form-input"
              placeholder={t('pages.testgen.frameworkPlaceholder', lang)}
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-email">{t('pages.testgen.email', lang)} *</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              class="form-input"
              required
              placeholder={t('pages.testgen.emailPlaceholder', lang)}
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="notes">{t('pages.testgen.notes', lang)}</label>
            <textarea
              id="notes"
              name="notes"
              class="form-textarea"
              placeholder={t('pages.testgen.notesPlaceholder', lang)}
            ></textarea>
          </div>

          <!-- Honeypot anti-bot field -->
          <div aria-hidden="true" style="position: absolute; left: -9999px; opacity: 0; height: 0; overflow: hidden;">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" name="_t" id="form-timestamp" />
          <input type="hidden" name="sessionId" id="session-id" />

          <button type="submit" class="btn btn-primary w-full">
            <span class="btn-text">{t('pages.testgen.submitButton', lang)}<IconArrowRight /></span>
          </button>

          <div id="form-status" class="form-status" role="alert" aria-live="polite" style="display: none;"></div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
const form = document.getElementById('testgen-form') as HTMLFormElement;
const statusEl = document.getElementById('form-status') as HTMLDivElement;
const timestampEl = document.getElementById('form-timestamp') as HTMLInputElement;
const sessionIdEl = document.getElementById('session-id') as HTMLInputElement;

// Set timestamp for anti-bot
if (timestampEl)
  timestampEl.value = String(Date.now());

// Read session_id from URL params
const urlParams = new URLSearchParams(window.location.search);
const sessionId = urlParams.get('session_id');
if (sessionIdEl && sessionId)
  sessionIdEl.value = sessionId;

if (form) {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = submitBtn.querySelector('.btn-text') as HTMLSpanElement;
    const originalHtml = btnText.innerHTML;
    submitBtn.disabled = true;
    btnText.textContent = form.dataset.sending || 'Submitting...';
    statusEl.style.display = 'none';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/testgen-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        statusEl.className = 'form-status form-status-success';
        statusEl.innerHTML = `<strong>${form.dataset.successTitle}</strong><p>${form.dataset.successMsg}</p>`;
        statusEl.style.display = 'block';
        form.reset();
        if (timestampEl)
          timestampEl.value = String(Date.now());
      }
      else {
        throw new Error('Request failed');
      }
    }
    catch {
      statusEl.className = 'form-status form-status-error';
      statusEl.innerHTML = `<strong>${form.dataset.errorTitle}</strong><p>${form.dataset.errorMsg}</p>`;
      statusEl.style.display = 'block';
    }
    finally {
      submitBtn.disabled = false;
      btnText.innerHTML = originalHtml;
    }
  });
}
</script>

<style>
.submit-form-wrapper {
  max-width: 600px;
  margin: 0 auto;
}

.form-status {
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  animation: fadeInStatus 0.3s ease;
}

.form-status-success {
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: rgb(34, 197, 94);
}

.form-status-error {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: rgb(239, 68, 68);
}

.form-status strong {
  display: block;
  margin-bottom: var(--space-xs);
}

.form-status p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
}

@keyframes fadeInStatus {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
