---
import IconAI from '../components/icons/IconAI.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';
import IconExternal from '../components/icons/IconExternal.astro';
import IconNuxt from '../components/icons/IconNuxt.astro';
import IconPython from '../components/icons/IconPython.astro';
import IconTailwind from '../components/icons/IconTailwind.astro';
import IconTypeScript from '../components/icons/IconTypeScript.astro';
import IconVue from '../components/icons/IconVue.astro';
import { t } from '../i18n/index.ts';
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout title={t('meta.portfolioTitle', lang)} description={t('meta.portfolioDescription', lang)} lang={lang}>
  <section class="page-header hero-portfolio">
    <div class="container">
      <span class="page-subtitle">{t('portfolio.tagline', lang)}</span>
      <h1>{t('portfolio.featured', lang)} <span class="text-gradient">{t('portfolio.projects', lang)}</span></h1>
      <p class="page-header-description">{t('portfolio.subtitle', lang)}</p>
      <a href="/contact" class="btn btn-primary mt-1">Discuss Your Project →</a>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="content-section reveal">
        <h2 class="section-title">{t('portfolio.aboutTitle', lang)}</h2>
        <p class="section-text">{t('portfolio.aboutDesc', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Project Showcase -->
  <section class="section">
    <div class="container">
      <div class="showcase-grid reveal">
        <!-- WELC -->
        <div class="showcase-item">
          <img class="showcase-image" src="/images/portfolio-crypto.webp" alt="WeLoveEverythingCrypto" loading="lazy" />
          <div class="showcase-overlay">
            <span class="showcase-tag">{t('portfolio.liveProject', lang)}</span>
            <h3 class="showcase-title">WeLoveEverythingCrypto</h3>
            <p>{t('portfolio.welcDesc', lang)}</p>
            <a href="https://weloveeverythingcrypto.com" target="_blank" rel="noopener" class="btn btn-primary">
              {t('portfolio.visitSite', lang)} <IconExternal />
            </a>
          </div>
        </div>

        <!-- Handball Stats -->
        <div class="showcase-item">
          <img class="showcase-image" src="/images/portfolio-handball.webp" alt="Handball Tracker" loading="lazy" />
          <div class="showcase-overlay">
            <span class="showcase-tag">{t('portfolio.liveProject', lang)}</span>
            <h3 class="showcase-title">Handball Tracker</h3>
            <p>{t('portfolio.handballDesc', lang)}</p>
            <a href="https://handballtracker.com" target="_blank" rel="noopener" class="btn btn-primary">
              {t('portfolio.visitSite', lang)} <IconExternal />
            </a>
          </div>
        </div>

        <!-- Let Me Claude That For You -->
        <div class="showcase-item">
          <img class="showcase-image" src="/images/portfolio-lmctfy.svg" alt="Let Me Claude That For You" loading="lazy" />
          <div class="showcase-overlay">
            <span class="showcase-tag">{t('portfolio.liveProject', lang)}</span>
            <h3 class="showcase-title">Let Me Claude That For You</h3>
            <p>{t('portfolio.lmctfyDesc', lang)}</p>
            <a href="https://letmeclaudethatforyou.live" target="_blank" rel="noopener" class="btn btn-primary">
              {t('portfolio.visitSite', lang)} <IconExternal />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Flagship Case Study -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">Case Study</span>
        <h2>WeLoveEverythingCrypto: <span class="text-gradient">Deep Dive</span></h2>
      </div>
      <div class="case-study reveal">
        <div class="case-study-grid">
          <div class="case-study-content">
            <h3>The Challenge</h3>
            <p>Build a multilingual cryptocurrency news platform that could compete with established players, delivering real-time data and AI-generated analysis across 5 languages — in weeks, not months.</p>

            <h3>The Approach</h3>
            <p>Using vibecoding (AI-assisted development) with Nuxt 4, we built the entire platform from scratch with SEO-first architecture, real-time price feeds, and automated content pipelines. Every page is statically generated for maximum performance and SEO value.</p>

            <h3>The Results</h3>
            <div class="case-metrics">
              <div class="case-metric">
                <span class="case-metric-number">1000+</span>
                <span class="case-metric-label">Articles Published</span>
              </div>
              <div class="case-metric">
                <span class="case-metric-number">5</span>
                <span class="case-metric-label">Languages</span>
              </div>
              <div class="case-metric">
                <span class="case-metric-number">&lt;1s</span>
                <span class="case-metric-label">Page Load Time</span>
              </div>
              <div class="case-metric">
                <span class="case-metric-number">100</span>
                <span class="case-metric-label">Lighthouse Score</span>
              </div>
            </div>
          </div>
          <div class="case-study-sidebar">
            <div class="case-detail">
              <strong>Client</strong>
              <p>WeLoveEverythingCrypto</p>
            </div>
            <div class="case-detail">
              <strong>Timeline</strong>
              <p>4 weeks initial build</p>
            </div>
            <div class="case-detail">
              <strong>Stack</strong>
              <p>Nuxt 4 · Vue 3 · TypeScript · Vercel</p>
            </div>
            <div class="case-detail">
              <strong>Services</strong>
              <p>Vibecoding · SEO · Content Strategy</p>
            </div>
            <a href="https://weloveeverythingcrypto.com" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: var(--space-md);">
              Visit Live Site →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Project Descriptions -->
  <section class="section">
    <div class="container">
      <div class="project-details">
        <div class="project-detail reveal">
          <h3>WeLoveEverythingCrypto</h3>
          <p>{t('portfolio.welcFullDesc', lang)}</p>
        </div>
        <div class="project-detail reveal">
          <h3>Handball Stats App</h3>
          <p>{t('portfolio.handballFullDesc', lang)}</p>
        </div>
        <div class="project-detail reveal">
          <h3>Let Me Claude That For You</h3>
          <p>{t('portfolio.lmctfyFullDesc', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technologies Section -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-3">
        <span class="hero-tagline">{t('common.howItWorks', lang)}</span>
        <h2>{t('portfolio.technologiesTitle', lang)}</h2>
        <p style="max-width: 700px; margin: 0 auto;">{t('portfolio.technologiesDesc', lang)}</p>
      </div>

      <div class="tech-grid reveal">
        <div class="tech-item">
          <div class="tech-icon"><IconVue /></div>
          <span class="tech-name">Vue 3</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><IconNuxt /></div>
          <span class="tech-name">Nuxt 4</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><IconTypeScript /></div>
          <span class="tech-name">TypeScript</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><IconTailwind /></div>
          <span class="tech-name">TailwindCSS</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><IconPython /></div>
          <span class="tech-name">Python</span>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><IconAI /></div>
          <span class="tech-name">AI APIs</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="card text-center" style="padding: var(--space-xl); max-width: 800px; margin: 0 auto;">
        <h2 class="mb-1">{t('cta.title', lang)}</h2>
        <p style="font-size: 1.25rem; margin-bottom: var(--space-md);">{t('cta.subtitle', lang)}</p>
        <a href={`${prefix}/contact`} class="btn btn-primary">
          {t('cta.button', lang)}
          <IconArrowRight />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header .text-gradient { color: #f59e0b; }
.page-header { border-bottom: 3px solid #f59e0b; }

.content-section {
  max-width: 800px;
  margin: 0 auto;
}

.section-title {
  margin-bottom: var(--space-md);
}

.section-text {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.project-details {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: var(--space-xl);
}

.project-detail {
  background: var(--bg-surface);
  padding: var(--space-lg);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
}

.project-detail h3 {
  margin-bottom: var(--space-md);
  color: var(--text-primary);
}

.project-detail p {
  color: var(--text-secondary);
  line-height: 1.8;
}

.tech-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: var(--space-md);
  max-width: 800px;
  margin: 0 auto;
}

.tech-item {
  background: var(--bg-surface);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  text-align: center;
  border: 1px solid var(--border-subtle);
}

.tech-name {
  font-weight: 600;
  color: var(--text-primary);
}

@media (max-width: 768px) {
  .project-details {
    grid-template-columns: 1fr;
  }
}
</style>
