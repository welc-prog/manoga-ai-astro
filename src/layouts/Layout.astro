---
import Analytics from '@vercel/analytics/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { t } from '../i18n/index.ts';
import '../styles/main.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  noindex?: boolean;
}

const { title, description, lang = 'en', noindex = false } = Astro.props;
const desc = description || t('meta.description', lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://www.manoga.digital${Astro.url.pathname}`} />
    <meta property="og:image" content="https://www.manoga.digital/images/ai-hero.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <link rel="canonical" href={`https://www.manoga.digital${Astro.url.pathname}`} />
    {!Astro.url.pathname.startsWith('/da/') && (
      <>
        <link rel="alternate" hreflang="en" href={`https://www.manoga.digital${Astro.url.pathname}`} />
        <link rel="alternate" hreflang="da" href={`https://www.manoga.digital/da${Astro.url.pathname}`} />
        <link rel="alternate" hreflang="x-default" href={`https://www.manoga.digital${Astro.url.pathname}`} />
      </>
    )}
    {Astro.url.pathname.startsWith('/da/') && (
      <>
        <link rel="alternate" hreflang="en" href={`https://www.manoga.digital${Astro.url.pathname.replace(/^\/da/, '')}`} />
        <link rel="alternate" hreflang="da" href={`https://www.manoga.digital${Astro.url.pathname}`} />
        <link rel="alternate" hreflang="x-default" href={`https://www.manoga.digital${Astro.url.pathname.replace(/^\/da/, '')}`} />
      </>
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Manoga Digital Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title} | Manoga Digital</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      'name': 'Manoga Digital',
      'url': 'https://www.manoga.digital',
      'description': 'Digital agency specializing in AI consulting, SEO, and web design',
      'sameAs': ['https://www.linkedin.com/company/manoga'],
    })}
    />
  </head>
  <body>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics />
  </body>
</html>
